{
  "name": "@ergo-raffle/ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:code": "tsc --build",
    "build:watch:code": "npm run build:code -- --watch",
    "build:styles": "tailwindcss -i ./src/styles/globals.css -o ./dist/styles.css",
    "build:watch:styles": "npm run build:styles -- --watch",
    "build": "npm-run-all build:code build:styles",
    "build:watch": "npm-run-all --parallel build:watch:*",
    "build:clear": "rimraf -rf ./dist"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.3.1",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.13",
    "@tailwindcss/postcss": "^4",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.0.1",
    "typescript": "^5",
    "@types/react": "^19",
    "@types/react-dom": "^19"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  }
}
