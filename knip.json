{
  "$schema": "https://unpkg.com/knip/schema.json",
  "workspaces": {
    "packages/*": {
      "entry": ["{lib,src}/**/*.{js,cjs,mjs,jsx,ts,cts,mts,tsx}"]
    },
    "apps/*": {
      "entry": ["{app,lib,src}/**/*.{js,cjs,mjs,jsx,ts,cts,mts,tsx}"]
    }
  },
  "ignoreBinaries": ["rollup"],
  "ignore": ["**/node_modules/", "**/dist/", "**/.next/"],
  "ignoreDependencies": ["tailwindcss", "@rollup/plugin-typescript"]
}
